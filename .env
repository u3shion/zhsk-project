# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# ─── Users service — database ─────────────────────────────────────────────────
USERS_DB_NAME=users_db
USERS_DB_USER=users_service
USERS_DB_PASSWORD=users_password

# ─── Users service — app ──────────────────────────────────────────────────────
USERS_PORT=8001
USERS_ADMIN_SECRET=supersecret123

# ─── Meters service — database ────────────────────────────────────────────────
METERS_DB_NAME=meters_db
METERS_DB_USER=meters_service
METERS_DB_PASSWORD=meters_password

# ─── Meters service — app ─────────────────────────────────────────────────────
METERS_PORT=8002

# ─── Shared secrets ───────────────────────────────────────────────────────────
SECRET_KEY=supersecretkey
